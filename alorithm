pipeline
{
agent any
    stages{
        stage ('installing docker')
        {
            steps{
                sh ''' yum install -y docker\n
                     systemctl start docker
                      docker pull httpd       '''

            }
        }
        stage ('Creating index file inside container') 
        {
        steps {
            sh ''' echo "Welcome to home page" > /mnt/index.html \n
             docker run -itdp 80:80 --name server1 httpd \n
             docker cp /mnt/index.html server1:/usr/local/apache2/htdocs '''  
            
        }
        }
    stage ('starting apache service')
    {
    steps {
        sh 'systemctl start httpd'
        sh 'systemctl enable httpd'
    }
    }   
    }
}
